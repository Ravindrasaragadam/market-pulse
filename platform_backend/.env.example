# Telegram Credentials
# Get these from https://my.telegram.org
TELEGRAM_API_ID=YOUR_API_ID
TELEGRAM_API_HASH=YOUR_API_HASH

# Bot API (for sending alerts)
# Get this from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_ALERT_CHAT_ID=YOUR_ALERT_CHAT_ID
TELEGRAM_SESSION_NAME=session
TELEGRAM_ALLOWED_CHAT_IDS=YOUR_SOURCE_CHANNEL_ID

# AI Brain
# Get this from https://build.nvidia.com
NVIDIA_NIM_API_KEY=YOUR_NVIDIA_NIM_KEY

# Database (Supabase)
# Get these from your Supabase Project Settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# Settings
INCLUDE_INTERNATIONAL=True
EVALUATION_INTERVAL_MINS=30

# Watchlist (Example Tickers)
WATCHLIST_SYMBOLS=CRSP,TWST,DNA,SMR,OKLO,NNE,NVDA,VRT,ANET,MU,GC=F,SI=F

# Focus Keywords for AI Brain
FOCUS_KEYWORDS=Synbio, SMR, Nuclear, Data Center, Grid Modernization, HBM, AI Diffusion, Gold, Silver
